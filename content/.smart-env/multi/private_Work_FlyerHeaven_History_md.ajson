"##{76}":[76,76],"##{77}":[77,77],"##{78}":[78,78],"##{79}":[79,79],"##{80}":[80,80],"##{81}":[81,81],"##{82}":[82,82],"##{83}":[83,83],"##{84}":[84,84],"##{85}":[85,85],"##{86}":[86,86],"##{87}":[87,87],"##{88}":[88,88],"##{89}":[89,89],"##{90}":[90,90],"##{91}":[91,91],"##{92}":[92,92],"##{93}":[93,93],"##{94}":[94,94],"##{95}":[95,95],"##{96}":[96,96],"##{97}":[97,97],"##{98}":[98,98],"##{99}":[99,99],"##{100}":[100,100],"##{101}":[101,101],"##{102}":[102,103],"#1268 Refactoring: Forgeron-Pfade aus imports.js entfernt, Importe in Komponenten verlagert.":[128,128],"#1270 Bug: Letztes Bild in MediaCollection kann nicht entfernt werden. New Media":[129,129],"#1212 Feature: `useForgeron()` Composable einführen; temporäre Daten über `ResourceRequest` verwalten.":[130,130],"#1278 Feature: Zeichenlimit 'Firma' (Adresse) auf 60 erhöht; Validierung & Zähler-UI angepasst.":[131,132],"#1278 Feature: Zeichenlimit 'Firma' (Adresse) auf 60 erhöht; Validierung & Zähler-UI angepasst.#{1}":[132,132],"#1290 Task: Barrierefreiheit im Frontend prüfen & unerfüllte Anforderungen für Folgetickets listen.":[133,133],"#1313 Refactor monolithic checkout component into smaller, single-responsibility child components for improved maintainability and performance.":[134,134],"#1316 Implement **separate navigation caches** for different admin areas (e.g., shop admin, customer admin) to prevent display issues when switching tabs.":[135,135],"#1325 Reintroduce missing address fields to the updated address UI to prevent data loss and ensure complete address and contact information capture.":[136,136],"#1328 Fix: Toggle-Buttons in Admin-Einstellungsgruppen sind jetzt funktionsfähig.":[137,137],"#888 Anpassung PDP für Kombiprodukte: Prinect-Status ausblenden, alle Bestandteile anzeigen.":[138,138],"#1333 Refactored PrintDataActions.vue into child components to reduce complexity and improve maintainability.":[139,139],"#1014 Checked and implemented Microsoft Advertising's consent mode for UET tags to meet privacy requirements.":[140,140],"#1341 Hid the dark mode toggle icon for all user roles except Techadmin and Admin.":[141,141],"#888 Adjusted combo product PDP: Removed 'Prinect-Status' column and now list all components, restricting view icons by user permissions.":[142,142],"#1237 Fixed shipping date selection: disabled unavailable dates, corrected cost display for \"on request\" shipping, and fixed validation errors.":[143,143],"#1296 Applied frontend address validation rules (character limits, required fields) to the admin area for consistency.":[144,144],"#1342 Replaced the MIME type with the correct file extension (e.g., jpg, pdf) in the downloads display.":[145,145],"#1305:Refactored the admin area to the new Forgeron structure, moving CSS/JS into a package and finalizing the new admin skin.":[146,147],"#1305:Refactored the admin area to the new Forgeron structure, moving CSS/JS into a package and finalizing the new admin skin.#{1}":[147,147],"#1365 Refactored address validation to use a single, centralized source for both frontend and backend rules to remove code duplication.":[148,148],"#780 Fixed the \"items per page\" selector and pagination, corrected the product count display, and unified the component's font.":[149,149],"#1377 : Improved the PDP layout for product properties: dropdowns are now larger, have closer labels, and an updated, more intuitive style.":[150,150],"#1376 Split the approvals area into \"Pending\" and \"Processed\" tabs to provide a clearer overview and separate open from completed tasks.":[151,151],"#1331 Fixed a bug where a new address created in the cart was not automatically selected; the new address is now set as active.":[152,153],"#1331 Fixed a bug where a new address created in the cart was not automatically selected; the new address is now set as active.#{1}":[153,153],"#1381 Re-enabled shipping and billing address selection, including a search function, in the checkout process within the MEO-Shop-Skin. And some other bugs":[154,155],"#1381 Re-enabled shipping and billing address selection, including a search function, in the checkout process within the MEO-Shop-Skin. And some other bugs###Contributions for **Sep 24, 2025**":[155,155]},"outlinks":[],"task_lines":[],"last_embed":{"hash":"1w7r7go","at":1761297939415}},"smart_blocks:private/Work/FlyerHeaven/History.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02587497,0.02214232,0.04367692,0.01292115,0.02040102,0.0325411,-0.0558704,0.00354828,-0.0113459,-0.05218026,-0.03678102,-0.04700824,0.03115064,0.04921962,0.01540489,0.02658891,0.01206577,0.06232515,-0.02384181,0.0079263,0.03257478,-0.02652081,0.05167953,-0.03770266,-0.00034761,0.08411416,-0.04024021,-0.10669772,0.02127265,-0.19149885,-0.03210419,-0.00754074,0.03028985,0.01234697,-0.00873641,0.00208762,-0.08263145,-0.00457951,-0.01981929,0.00606306,0.00351507,0.03804944,-0.04457625,-0.05780707,-0.01381044,-0.05703232,0.08965201,-0.01858165,-0.03839521,0.03114991,0.00447827,-0.00832276,0.00147008,-0.00223963,0.06130347,0.03309385,0.01391725,0.08101507,0.00568035,0.01017086,-0.00001262,0.00675651,-0.25124994,0.11569492,-0.00718063,0.01382038,-0.04631703,-0.0345511,-0.0346309,0.08599253,-0.0150637,0.01860397,0.04197254,0.06370097,0.01215167,0.02512355,0.04888816,-0.06673106,-0.02143316,-0.00225723,0.00605975,0.00554091,-0.00419607,0.00888506,0.01380696,-0.0996832,0.07174853,-0.02457652,0.05000779,-0.02657144,-0.03496042,-0.02714884,0.06761944,-0.0439906,-0.00005218,-0.01904538,0.00251016,0.00804443,-0.02577975,0.079898,-0.00868879,0.0731395,0.05495397,-0.00276049,0.04022866,-0.03222849,-0.00447034,0.02999274,-0.07544126,-0.01360204,-0.07212718,0.01073794,0.1335481,0.00904801,0.04068525,0.0220145,-0.00990645,-0.07654003,0.01333633,-0.00327811,0.04878156,0.02426482,0.04490711,0.03259891,0.00808974,-0.0064824,0.05804224,0.0491472,-0.04456141,0.06744409,0.02291691,0.03548796,-0.02581351,-0.01243676,-0.02864963,-0.0182002,0.01652852,0.02507304,0.01549766,-0.005